DATABASE_URL=postgres://user:password@localhost:5432/dbname
POSTGRES_MCP_QUERY_TIMEOUT=30s
POSTGRES_MCP_MAX_ROWS=500
POSTGRES_MCP_POOL_SIZE=5
POSTGRES_MCP_ALLOW_DML=false
POSTGRES_MCP_ALLOW_DDL=false
POSTGRES_MCP_ALLOW_DCL=false
POSTGRES_MCP_ALLOW_TRANSACTIONS=false
POSTGRES_MCP_ALLOW_DIAGNOSTICS=false
POSTGRES_MCP_ALLOW_EXPLAIN_ANALYZE=false
