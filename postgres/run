set -euo pipefail
shopt -s globstar
trap 'echo fatal: $0:$LINENO >&2' ERR

cd "$(dirname "$0")"

cmd="${1:-help}"

build_arch() {
  version="$(git describe --tags --abbrev=0 --match 'postgres/*')"
  version="${version#postgres/}"
  commit="$(git rev-parse --short HEAD)"
  date="$(date +%Y.%m.%d.%H:%M)"

  docker buildx build --platform "$1" \
    --build-arg VERSION="${version}_${commit}_$date" \
    -t ghcr.io/rthomazel/mcp/postgres:latest \
    --load .
}

case "$cmd" in
# -- run golangci-lint
lint)
  go tool golangci-lint run ./...
  ;;
# -- start the server (requires postgres-mcp.yaml)
dev)
  go run main.go
  ;;
# -- run tests
test)
  go test -race ./...
  ;;
# -- run formatters
format)
  go tool gofumpt -l -w .
  ;;
# -- build local binary to bin/postgres-mcp
build:go)
  go build -o bin/postgres-mcp main.go
  ;;
# -- build versioned docker image for amd64
build:amd64)
  build_arch "linux/amd64"
  ;;
# -- build versioned docker image for arm64
build:arm64)
  build_arch "linux/arm64"
  ;;
help | *)
  echo "Usage: postgres/run <command>"
  echo ""
  echo "Commands:"
  awk '/^# -- /{desc=substr($0, index($0,"-- ")+3)} /\)$/ && desc{cmd=$0; gsub(/[[:space:]()|*]/, "", cmd); printf "  %-20s %s\n", cmd, desc; desc=""}' "$(basename "$0")"
  ;;
esac
