set -euo pipefail
shopt -s globstar
trap 'echo fatal: $0:$LINENO >&2' ERR

# AGENTS: run commands directly, you cannot execute this file. if making changes to this file, run chmod u+x on it.
cmd="${1:-help}"

case "$cmd" in
# -- delegate to bench/run
bench:*)
  exec bench/run "${cmd#bench:}"
  ;;
help | *)
  echo "Usage: ./run <command>"
  echo ""
  echo "Bench commands (delegated to bench/run):"
  bench/run help | tail -n +3
  ;;
esac
